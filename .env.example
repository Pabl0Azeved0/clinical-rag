# LLM provider selection — all optional (defaults defined in config.py)
# Keys are never committed. Copy this file to .env and fill in as needed.

# LLM_PROVIDER=ollama           # ollama | gemini | groq
# LLM_MODEL=llama3.2:3b
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=                  # required for gemini / groq; leave blank for ollama
